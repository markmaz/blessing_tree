# Blessing Tree container runtime environment
CURRENT_ENVIRONMENT=production

# Caddy public entrypoint. Use ":80" for local HTTP-only testing.
# For production HTTPS, set this to the public domain, for example:
# BT_SITE_ADDRESS=blessingtree.example.org
BT_SITE_ADDRESS=:80
BT_HTTP_PORT=80
BT_HTTPS_PORT=443

# RDS MySQL
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=blessing_tree
POOL_SIZE=10
MAX_OVERFLOW=20
POOL_TIMEOUT=30
POOL_RECYCLE=1800

# Auth and cookies
JWT_SECRET=
SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ISSUER=blessing-tree-api
JWT_AUDIENCE=blessing-tree-ui
JWT_LEEWAY_SECONDS=120
JWT_VERIFY_IAT=false
ACCESS_TOKEN_TTL_MINUTES=10
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=21
REFRESH_TOKEN_TTL_SECONDS=1209600
REFRESH_COOKIE_NAME=bt_refresh
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=Lax
REFRESH_COOKIE_PATH=/api/v1/auth
COOKIE_SECURE=true
COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

# Public URLs
FRONTEND_BASE_URL=https://example.com
INVITE_URL=https://example.com/auth/register
PASSWORD_RESET_URL=https://example.com/auth/reset-password
ORGANIZATION_NAME=Blessing Tree
BT_TRUSTED_PROXY_IPS=*

# Valkey. For bundled Compose Valkey, leave host as valkey.
VALKEY_ADDRESS=valkey
VALKEY_PORT=6379
VALKEY_DB=0
VALKEY_PASSWORD=
VALKEY_SSL=false
LOG_QUEUE=API_LOG
BT_CELERY_WORKER_POOL=prefork
BT_CELERY_WORKER_CONCURRENCY=1
BT_CAMPAIGN_AUTOMATION_POLL_SECONDS=60
BT_CAMPAIGN_LIFECYCLE_POLL_SECONDS=300
BT_CAMPAIGN_AUTOMATION_HEARTBEAT_TTL_SECONDS=180

# Password policy and mail
PASSWORD_CHECK_URL=https://api.pwnedpasswords.com/range/
MIN_PASSWORD_LENGTH=8
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SERVER=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
DEFAULT_MAIL_SENDER=

# Optional integrations
GEOAPIFY_API_KEY=
BT_ADDRESS_AUTOCOMPLETE_COUNTRY_CODE=us
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT_S=30
