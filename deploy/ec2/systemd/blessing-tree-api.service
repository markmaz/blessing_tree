[Unit]
Description=Blessing Tree API
After=network.target

[Service]
Type=simple
User=blessingtree
Group=blessingtree
WorkingDirectory=/opt/blessing-tree/current/blessing-tree-api
EnvironmentFile=/opt/blessing-tree/shared/api.env
ExecStart=/opt/blessing-tree/current/blessing-tree-api/.venv/bin/gunicorn --bind 127.0.0.1:5000 --workers 3 --timeout 120 app.main:blessing_tree
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
