# Runtime environment
CURRENT_ENVIRONMENT=development
BT_LOG_LEVEL=INFO
BT_LOG_FORMAT=human
BT_LOG_TO_CONSOLE=true
BT_LOG_TO_FILE=true
BT_LOG_FILE=logs/blessing-tree-api.log
BT_LOG_MAX_BYTES=10485760
BT_LOG_BACKUP_COUNT=5

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=blessing_tree
POOL_SIZE=10
MAX_OVERFLOW=20
POOL_TIMEOUT=30
POOL_RECYCLE=1800

# JWT and auth
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ISSUER=blessing-tree-api
JWT_AUDIENCE=blessing-tree-ui
JWT_LEEWAY_SECONDS=120
JWT_VERIFY_IAT=false
ACCESS_TOKEN_TTL_MINUTES=10
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=21
REFRESH_TOKEN_TTL_SECONDS=1209600
OTP_VALID_WINDOW=2

# Refresh cookie
REFRESH_COOKIE_NAME=bt_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=Lax
REFRESH_COOKIE_PATH=/api/v1/auth
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# Frontend-facing URLs
FRONTEND_BASE_URL=http://localhost:5173
INVITE_URL=http://localhost:5173/auth/register
PASSWORD_RESET_URL=http://localhost:5173/auth/reset-password
ORGANIZATION_NAME=Blessing Tree
GEOAPIFY_API_KEY=
BT_ADDRESS_AUTOCOMPLETE_COUNTRY_CODE=us

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/google/callback
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=http://localhost:5000/api/v1/auth/yahoo/callback

# Valkey / Redis-compatible services
VALKEY_ADDRESS=localhost
VALKEY_PORT=6379
VALKEY_DB=0
VALKEY_PASSWORD=
VALKEY_SSL=false
LOG_QUEUE=API_LOG
BT_CELERY_WORKER_POOL=solo
BT_CELERY_WORKER_CONCURRENCY=1
BT_CAMPAIGN_AUTOMATION_POLL_SECONDS=60
BT_CAMPAIGN_LIFECYCLE_POLL_SECONDS=300
BT_CAMPAIGN_AUTOMATION_HEARTBEAT_TTL_SECONDS=180

# Password policy and mail
PASSWORD_CHECK_URL=https://api.pwnedpasswords.com/range/
MIN_PASSWORD_LENGTH=8
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SERVER=
SMTP_PORT=587
DEFAULT_MAIL_SENDER=

# Reserved / currently inactive backend integrations
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT_S=30
BT_ASK_VECTOR_ENABLED=true
BT_ASK_KNOWLEDGE_COLLECTION=blessing_tree_ask_knowledge
BT_ASK_EMBEDDING_MODEL=text-embedding-3-small
BT_ASK_VECTOR_MIN_SCORE=0.62
QDRANT_DOMAIN_COLLECTION=domain_catalog
QDRANT_TABLE_COLLECTION=table_catalog
QDRANT_COLUMN_COLLECTION=column_catalog
QDRANT_COLUMN_COLLECTION_V2=column_catalog_v2
